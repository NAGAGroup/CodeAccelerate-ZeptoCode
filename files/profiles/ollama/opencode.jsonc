{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "small_model": "ollama/opencode-model",
  "plugin": ["file://{env:HOME}/.config/opencode/plugins/planning-enforcement.js"],
  "default_agent": "headwrench",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:{env:OPENCODE_OLLAMA_PORT}/v1"
      },
      "models": {
        "opencode-model": {
          "name": "Default Ollama",
          "options": {
            "reasoningEffort": "high"
          }
        }
      }
    }
  },
  // Recommended model (2026, RTX 4090 24GB VRAM):
  //   ollama pull qwen3:14b
  //   Minimum-supported model for planning sessions — all prompts are engineered to this baseline.
  //   Tool-calling reliable with think: false (see model options above); ~60% failure rate with thinking enabled.
  //   VRAM: ~9-10GB at Q4_K_M; Context: 32K native; set num_ctx 16384 in Modelfile for safe VRAM margin
  //
  // KV cache optimization (cuts context VRAM ~50%):
  //   export OLLAMA_KV_CACHE_TYPE=q8_0
  //   export OLLAMA_FLASH_ATTENTION=1
  //   ollama serve
  //
  // Secondary: mistral-small (24B, Q4_K_M, ~15.9GB, purpose-built function calling, Medium confidence)
  //   ollama pull mistral-small
  //   OR: ollama pull hf.co/bartowski/Mistral-Small-3.2-24B-Instruct-2506-GGUF:Q4_K_M
  // Alternative: qwen3:32b (32B, Q4_K_M, ~20.7GB, agentic design, same think: false applies)
  // Fallback: qwen2.5:14b (Q4_K_M, 9-10GB, 97.1% tool-calling F1, no thinking mode)
  // Do NOT use 70B+ models — zero VRAM for KV cache, context collapses to <2K
  // Full report: docs/reports/ollama-model-recommendations.md
  "agent": {
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "headwrench": {
      "model": "ollama/opencode-model"
    },
    "context-scout": {
      "model": "ollama/opencode-model"
    },
    "documentation-expert": {
      "model": "ollama/opencode-model"
    },
    "junior-dev": {
      "model": "ollama/opencode-model"
    },
    "context-insurgent": {
      "model": "ollama/opencode-model"
    },
    "external-scout": {
      "model": "ollama/opencode-model"
    },
    "deep-researcher": {
      "model": "ollama/opencode-model"
    },
    "tailwrench": {
      "model": "ollama/opencode-model"
    },
    "autonomous-agent": {
      "model": "ollama/opencode-model"
    },
    "dag-designer": {
      "model": "ollama/opencode-model"
    },
    "dag-description-author": {
      "model": "ollama/opencode-model"
    },
    "dag-reviewer": {
      "model": "ollama/opencode-model"
    },
    "dag-reviser": {
      "model": "ollama/opencode-model"
    },
    "compaction": {
      "model": "ollama/opencode-model"
    }
  },
  "mcp": {
    // File operations: read, write, edit, create directories, move files, search files by name.
    // Replaces built-in read/write/edit/glob tools for subagents.
    // Requires npx. Scoped to the current working directory.
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "."],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    // Semantic session memory. Stores and retrieves findings by meaning across DAG steps.
    // Connects to a shared Qdrant server instance (supports concurrent sessions).
    // Start the server once: docker run -d --name qdrant -p 6333:6333 qdrant/qdrant
    // Or without Docker: uvx mcp-server-qdrant
    "qdrant": {
      "type": "local",
      "command": ["uvx", "mcp-server-qdrant"],
      "environment": {
        "QDRANT_URL": "http://localhost:6333",
        "EMBEDDING_MODEL": "sentence-transformers/all-MiniLM-L6-v2"
      },
      "enabled": true,
      "timeout": 30000
    },
    // Self-hosted web search. Requires a running SearXNG instance on localhost:8080.
    // To spin up a local instance: docker run -d -p 8080:8080 searxng/searxng
    "searxng": {
      "type": "local",
      "command": ["npx", "-y", "mcp-searxng"],
      "environment": {
        "SEARXNG_URL": "http://localhost:8080"
      },
      "enabled": true
    }
  }
}