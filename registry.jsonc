{
  "$schema": "https://ocx.kdco.dev/schemas/v2/registry.json",
  "name": "Naga Group",
  "version": "1.1.1",
  "author": "Jack Myers",
  "opencode": "1.27.0",
  "ocx": "1.0.16",
  "components": [
    {
      "name": "ocx-planning-plugin",
      "type": "plugin",
      "description": "PicoCode — DAG-driven planning and execution plugin for OpenCode",
      "files": [
        "plugins/planning-enforcement.js",
        // Plan session DAG
        "planning/plan-session/plan.jsonl",
        // Planning prompts
        "planning/plan-session/prompts/session-overview.md",
        "planning/plan-session/prompts/orientation-scout.md",
        "planning/plan-session/prompts/external-research.md",
        "planning/plan-session/prompts/draft-plan.md",
        "planning/plan-session/prompts/plan-success.md",
        // Node library: backend nodes
        "planning/plan-session/node-library/execution-kickoff/node-spec.json",
        "planning/plan-session/node-library/execution-kickoff/prompt.md",
        // Node library: search nodes
        "planning/plan-session/node-library/context-scout/node-spec.json",
        "planning/plan-session/node-library/context-scout/prompt.md",
        "planning/plan-session/node-library/context-insurgent/node-spec.json",
        "planning/plan-session/node-library/context-insurgent/prompt.md",
        "planning/plan-session/node-library/external-scout/node-spec.json",
        "planning/plan-session/node-library/external-scout/prompt.md",
        "planning/plan-session/node-library/deep-research/node-spec.json",
        "planning/plan-session/node-library/deep-research/prompt.md",
        // Node library: work nodes
        "planning/plan-session/node-library/junior-dev-work-item/node-spec.json",
        "planning/plan-session/node-library/junior-dev-work-item/prompt.md",
        "planning/plan-session/node-library/junior-dev-fix-item/node-spec.json",
        "planning/plan-session/node-library/junior-dev-fix-item/prompt.md",
        "planning/plan-session/node-library/documentation-expert-work-item/node-spec.json",
        "planning/plan-session/node-library/documentation-expert-work-item/prompt.md",
        "planning/plan-session/node-library/documentation-expert-fix-item/node-spec.json",
        "planning/plan-session/node-library/documentation-expert-fix-item/prompt.md",
        // Node library: verification nodes
        "planning/plan-session/node-library/verify-work-item/node-spec.json",
        "planning/plan-session/node-library/verify-work-item/prompt.md",
        "planning/plan-session/node-library/verify-triage/node-spec.json",
        "planning/plan-session/node-library/verify-triage/prompt.md",
        // Node library: decision nodes
        "planning/plan-session/node-library/decision-gate/node-spec.json",
        "planning/plan-session/node-library/decision-gate/prompt.md",
        "planning/plan-session/node-library/user-decision-gate/node-spec.json",
        "planning/plan-session/node-library/user-decision-gate/prompt.md",
        // Node library: utility nodes
        "planning/plan-session/node-library/user-discussion/node-spec.json",
        "planning/plan-session/node-library/user-discussion/prompt.md",
        "planning/plan-session/node-library/write-notes/node-spec.json",
        "planning/plan-session/node-library/write-notes/prompt.md",
        "planning/plan-session/node-library/project-setup/node-spec.json",
        "planning/plan-session/node-library/project-setup/prompt.md",
        "planning/plan-session/node-library/commit/node-spec.json",
        "planning/plan-session/node-library/commit/prompt.md",
        "planning/plan-session/node-library/autonomous-work/node-spec.json",
        "planning/plan-session/node-library/autonomous-work/prompt.md"
      ]
    },
    {
      "name": "ocx-bundle",
      "type": "bundle",
      "description": "PicoCode — agents, commands, and skills",
      "files": [
        // Agents
        "agents/autonomous-agent.md",
        "agents/context-insurgent.md",
        "agents/context-scout.md",
        "agents/documentation-expert.md",
        "agents/deep-researcher.md",
        "agents/external-scout.md",
        "agents/headwrench.md",
        "agents/junior-dev.md",
        "agents/tailwrench.md",
        // Commands
        "commands/activate-plan.md",
        "commands/plan-session.md",
        // Skills
        "skills/planning-schema/SKILL.md",
        "skills/following-plans/SKILL.md"
      ]
    },
    {
      "name": "ocx-default",
      "type": "profile",
      "description": "PicoCode — Anthropic profile (Sonnet + Haiku)",
      "files": [
        { "path": "profiles/default/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/default/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    },
    {
      "name": "ocx-copilot",
      "type": "profile",
      "description": "PicoCode — GitHub Copilot profile",
      "files": [
        { "path": "profiles/copilot/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/copilot/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    },
    {
      "name": "ocx-haiku",
      "type": "profile",
      "description": "PicoCode — Anthropic Haiku profile (all Haiku models)",
      "files": [
        { "path": "profiles/haiku/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/haiku/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    },
    {
      "name": "ocx-haiku-copilot",
      "type": "profile",
      "description": "PicoCode — Haiku + GitHub Copilot profile",
      "files": [
        { "path": "profiles/haiku-copilot/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/haiku-copilot/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    },
    {
      "name": "ocx-free",
      "type": "profile",
      "description": "PicoCode — free tier profile (OpenCode free models)",
      "files": [
        { "path": "profiles/free/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/free/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    },
    {
      "name": "ocx-ollama",
      "type": "profile",
      "description": "PicoCode — fully local Ollama profile (run 'ollama cp <model> opencode-model' to set your model)",
      "files": [
        { "path": "profiles/ollama/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/ollama/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    }
  ]
}
