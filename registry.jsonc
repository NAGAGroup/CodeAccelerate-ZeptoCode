{
  "$schema": "https://ocx.kdco.dev/schemas/v2/registry.json",
  "name": "Naga Group",
  "version": "1.2.0",
  "author": "Jack Myers",
  "opencode": "1.27.0",
  "ocx": "1.0.16",
  "components": [
    {
      "name": "ocx-planning-plugin",
      "type": "plugin",
      "description": "PicoCode — DAG-driven planning and execution plugin for OpenCode",
      "files": [
        "plugins/planning-enforcement.js",
        // Plan session DAG
        "planning/plan-session/plan.jsonl",
        // Planning prompts
        "planning/plan-session/prompts/session-overview.md",
        "planning/plan-session/prompts/orientation-scout.md",
        "planning/plan-session/prompts/external-research.md",
        "planning/plan-session/prompts/draft-plan.md",
        "planning/plan-session/prompts/plan-success.md",
        // Node library: entry-phase
        "planning/plan-session/node-library/entry-phase/phase-schema.toml",
        "planning/plan-session/node-library/entry-phase/phase-spec.jsonl",
        "planning/plan-session/node-library/entry-phase/execution-kickoff/node-spec.json",
        "planning/plan-session/node-library/entry-phase/execution-kickoff/prompt.md",
        // Node library: collaborate
        "planning/plan-session/node-library/collaborate/phase-schema.toml",
        "planning/plan-session/node-library/collaborate/phase-spec.jsonl",
        "planning/plan-session/node-library/collaborate/context-scout/node-spec.json",
        "planning/plan-session/node-library/collaborate/context-scout/prompt.md",
        "planning/plan-session/node-library/collaborate/external-scout/node-spec.json",
        "planning/plan-session/node-library/collaborate/external-scout/prompt.md",
        "planning/plan-session/node-library/collaborate/context-insurgent/node-spec.json",
        "planning/plan-session/node-library/collaborate/context-insurgent/prompt.md",
        "planning/plan-session/node-library/collaborate/collaborate/node-spec.json",
        "planning/plan-session/node-library/collaborate/collaborate/prompt.md",
        // Node library: deliberate
        "planning/plan-session/node-library/deliberate/phase-schema.toml",
        "planning/plan-session/node-library/deliberate/phase-spec.jsonl",
        "planning/plan-session/node-library/deliberate/context-scout/node-spec.json",
        "planning/plan-session/node-library/deliberate/context-scout/prompt.md",
        "planning/plan-session/node-library/deliberate/external-scout/node-spec.json",
        "planning/plan-session/node-library/deliberate/external-scout/prompt.md",
        "planning/plan-session/node-library/deliberate/context-insurgent/node-spec.json",
        "planning/plan-session/node-library/deliberate/context-insurgent/prompt.md",
        "planning/plan-session/node-library/deliberate/deliberate/node-spec.json",
        "planning/plan-session/node-library/deliberate/deliberate/prompt.md",
        // Node library: implement-code
        "planning/plan-session/node-library/implement-code/phase-schema.toml",
        "planning/plan-session/node-library/implement-code/phase-spec.jsonl",
        "planning/plan-session/node-library/implement-code/context-scout/node-spec.json",
        "planning/plan-session/node-library/implement-code/context-scout/prompt.md",
        "planning/plan-session/node-library/implement-code/external-scout/node-spec.json",
        "planning/plan-session/node-library/implement-code/external-scout/prompt.md",
        "planning/plan-session/node-library/implement-code/context-insurgent/node-spec.json",
        "planning/plan-session/node-library/implement-code/context-insurgent/prompt.md",
        "planning/plan-session/node-library/implement-code/project-setup/node-spec.json",
        "planning/plan-session/node-library/implement-code/project-setup/prompt.md",
        "planning/plan-session/node-library/implement-code/junior-dev-work-item/node-spec.json",
        "planning/plan-session/node-library/implement-code/junior-dev-work-item/prompt.md",
        "planning/plan-session/node-library/implement-code/verify-work-item/node-spec.json",
        "planning/plan-session/node-library/implement-code/verify-work-item/prompt.md",
        "planning/plan-session/node-library/implement-code/junior-dev-triage/node-spec.json",
        "planning/plan-session/node-library/implement-code/junior-dev-triage/prompt.md",
        "planning/plan-session/node-library/implement-code/write-notes/node-spec.json",
        "planning/plan-session/node-library/implement-code/write-notes/prompt.md",
        // Node library: author-documentation
        "planning/plan-session/node-library/author-documentation/phase-schema.toml",
        "planning/plan-session/node-library/author-documentation/phase-spec.jsonl",
        "planning/plan-session/node-library/author-documentation/context-scout/node-spec.json",
        "planning/plan-session/node-library/author-documentation/context-scout/prompt.md",
        "planning/plan-session/node-library/author-documentation/external-scout/node-spec.json",
        "planning/plan-session/node-library/author-documentation/external-scout/prompt.md",
        "planning/plan-session/node-library/author-documentation/context-insurgent/node-spec.json",
        "planning/plan-session/node-library/author-documentation/context-insurgent/prompt.md",
        "planning/plan-session/node-library/author-documentation/author-documentation/node-spec.json",
        "planning/plan-session/node-library/author-documentation/author-documentation/prompt.md",
        // Node library: finish
        "planning/plan-session/node-library/finish/phase-schema.toml",
        "planning/plan-session/node-library/finish/phase-spec.jsonl",
        "planning/plan-session/node-library/finish/write-notes/node-spec.json",
        "planning/plan-session/node-library/finish/write-notes/prompt.md"
      ]
    },
    {
      "name": "ocx-bundle",
      "type": "bundle",
      "description": "PicoCode — agents, commands, and skills",
      "files": [
        // Agents
        "agents/context-insurgent.md",
        "agents/context-scout.md",
        "agents/documentation-expert.md",
        "agents/deep-researcher.md",
        "agents/external-scout.md",
        "agents/headwrench.md",
        "agents/junior-dev.md",
        "agents/tailwrench.md",
        // Commands
        "commands/activate-plan.md",
        "commands/plan-session.md",
        // Skills
        "skills/planning-schema/SKILL.md",
        "skills/following-plans/SKILL.md"
      ]
    },
    {
      "name": "ocx-default",
      "type": "profile",
      "description": "PicoCode — Anthropic profile (Sonnet + Haiku)",
      "files": [
        { "path": "profiles/default/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/default/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    },
    {
      "name": "ocx-copilot",
      "type": "profile",
      "description": "PicoCode — GitHub Copilot profile",
      "files": [
        { "path": "profiles/copilot/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/copilot/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    },
    {
      "name": "ocx-haiku",
      "type": "profile",
      "description": "PicoCode — Anthropic Haiku profile (all Haiku models)",
      "files": [
        { "path": "profiles/haiku/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/haiku/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    },
    {
      "name": "ocx-haiku-copilot",
      "type": "profile",
      "description": "PicoCode — Haiku + GitHub Copilot profile",
      "files": [
        { "path": "profiles/haiku-copilot/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/haiku-copilot/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    },
    {
      "name": "ocx-free",
      "type": "profile",
      "description": "PicoCode — free tier profile (OpenCode free models)",
      "files": [
        { "path": "profiles/free/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/free/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    },
    {
      "name": "ocx-ollama",
      "type": "profile",
      "description": "PicoCode — fully local Ollama profile (run 'ollama cp <model> opencode-model' to set your model)",
      "files": [
        { "path": "profiles/ollama/opencode.jsonc", "target": "opencode.jsonc" },
        { "path": "profiles/ollama/ocx.jsonc", "target": "ocx.jsonc" }
      ],
      "dependencies": ["ocx-bundle"]
    }
  ]
}
